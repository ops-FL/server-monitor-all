<!-- pages/manage/manage.wxml -->
<view class="page">
  <view class="header">
    <text class="title">服务器管理</text>
    <view class="header-actions">
      <button class="btn-import" bindtap="showImport">导入</button>
      <button class="btn-export" bindtap="exportData">导出</button>
      <button class="btn-config" bindtap="showGlobalConfig">⚙配置</button>
      <button class="btn-add" bindtap="showAdd">+ 新增</button>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索IP或名称" value="{{searchKey}}" bindinput="onSearchInput" />
    <text class="search-clear" bindtap="clearSearch" wx:if="{{searchKey}}">✕</text>
  </view>

  <!-- 服务器列表 -->
  <view class="server-list">
    <view class="server-item" wx:for="{{list}}" wx:key="host">
      <view class="server-info" bindtap="goDetail" data-host="{{item.host}}">
        <view class="server-name">
          <text class="name">{{item.name || item.host}}</text>
          <text class="host-ip">{{item.host}}</text>
        </view>
        <view class="server-meta">
          <text class="tag {{item.status}}">{{item.status === 'alive' ? '在线' : item.status === 'slow' ? '延迟' : '离线'}}</text>
          <text class="group" wx:if="{{item.group}}">{{item.group}}</text>
        </view>
      </view>
      <view class="server-actions">
        <button class="btn-edit" bindtap="editServer" data-host="{{item.host}}" data-name="{{item.name}}" data-sshuser="{{item.sshUser}}" data-sshpassword="{{item.sshPassword}}" data-sshport="{{item.sshPort}}" data-group="{{item.group}}">编辑</button>
        <button class="btn-threshold" bindtap="editThreshold" data-host="{{item.host}}" data-name="{{item.name}}">阈值</button>
        <button class="btn-delete" bindtap="confirmDelete" data-host="{{item.host}}" data-name="{{item.name}}">删除</button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{list.length === 0 && !loading}}">
    <text>暂无服务器</text>
  </view>

  <!-- 新增/编辑弹窗 -->
  <view class="modal" wx:if="{{showAddModal}}">
    <view class="modal-content">
      <text class="modal-title">{{editMode ? '编辑服务器' : '新增服务器'}}</text>
      <input class="modal-input" placeholder="IP地址" value="{{addForm.host}}" bindinput="onAddHost" disabled="{{editMode}}" wx:if="{{!editMode}}" />
      <text class="modal-ip" wx:if="{{editMode}}">IP: {{addForm.host}}</text>
      <input class="modal-input" placeholder="名称" value="{{addForm.name}}" bindinput="onAddName" />
      <input class="modal-input" placeholder="分组" value="{{addForm.group}}" bindinput="onAddGroup" />
      <view class="section-title">SSH 连接信息</view>
      <input class="modal-input" placeholder="SSH用户（默认root）" value="{{addForm.sshUser}}" bindinput="onAddSshUser" />
      <input class="modal-input" placeholder="SSH密码" value="{{addForm.sshPassword}}" bindinput="onAddSshPassword" password="true" />
      <input class="modal-input" placeholder="SSH端口（默认22）" type="number" value="{{addForm.sshPort}}" bindinput="onAddSshPort" />
      <view class="modal-actions">
        <button class="modal-cancel" bindtap="closeAdd">取消</button>
        <button class="modal-confirm" bindtap="doAdd">{{editMode ? '保存' : '确认新增'}}</button>
      </view>
    </view>
  </view>

  <!-- 阈值弹窗 -->
  <view class="modal" wx:if="{{showThresholdModal}}">
    <view class="modal-content">
      <text class="modal-title">告警阈值 - {{thresholdForm.name || thresholdForm.host}}</text>
      <view class="threshold-row">
        <text class="threshold-label">CPU (%)</text>
        <input class="threshold-input" type="number" value="{{thresholdForm.cpu}}" bindinput="onThCpu" />
      </view>
      <view class="threshold-row">
        <text class="threshold-label">内存 (%)</text>
        <input class="threshold-input" type="number" value="{{thresholdForm.mem}}" bindinput="onThMem" />
      </view>
      <view class="threshold-row">
        <text class="threshold-label">磁盘 (%)</text>
        <input class="threshold-input" type="number" value="{{thresholdForm.disk}}" bindinput="onThDisk" />
      </view>
      <view class="threshold-row">
        <text class="threshold-label">TCP 连接数</text>
        <input class="threshold-input" type="number" value="{{thresholdForm.tcp}}" bindinput="onThTcp" />
      </view>
      <view class="threshold-row">
        <text class="threshold-label">机器人 Webhook</text>
        <input class="threshold-input" placeholder="留空使用默认" value="{{thresholdForm.webhook}}" bindinput="onThWebhook" />
      </view>
      <view class="modal-actions">
        <button class="modal-cancel" bindtap="closeThreshold">取消</button>
        <button class="modal-confirm" bindtap="saveThreshold">保存</button>
      </view>
    </view>
  </view>

  <!-- 全局配置弹窗 -->
  <view class="modal" wx:if="{{showConfigModal}}">
    <view class="modal-content">
      <text class="modal-title">全局告警配置</text>
      <view class="threshold-row">
        <text class="threshold-label">Webhook URL</text>
        <input class="threshold-input" placeholder="企业微信机器人地址" value="{{globalWebhook}}" bindinput="onGlobalWebhook" />
      </view>
      <view class="modal-actions">
        <button class="modal-cancel" bindtap="closeGlobalConfig">取消</button>
        <button class="modal-confirm" bindtap="saveGlobalConfig">保存</button>
      </view>
    </view>
  </view>

  <!-- 导入弹窗 -->
  <view class="modal" wx:if="{{showImportModal}}">
    <view class="modal-content">
      <text class="modal-title">导入服务器</text>
      <textarea class="import-textarea" placeholder="每行一个，格式：IP,名称,分组&#10;示例：&#10;192.168.1.10,web-01,web&#10;192.168.1.20,db-01,db" value="{{importText}}" bindinput="onImportText" />
      <view class="modal-actions">
        <button class="modal-cancel" bindtap="closeImport">取消</button>
        <button class="modal-confirm" bindtap="doImport">导入</button>
      </view>
    </view>
  </view>

  <!-- 删除确认弹窗 -->
  <view class="modal" wx:if="{{showDeleteModal}}">
    <view class="modal-content">
      <text class="modal-title">确认删除</text>
      <text class="modal-desc">确定要删除服务器「{{deleteTarget.name || deleteTarget.host}}」吗？&#10;相关监控数据不会被删除。</text>
      <view class="modal-actions">
        <button class="modal-cancel" bindtap="closeDelete">取消</button>
        <button class="btn-delete-confirm" bindtap="doDelete">确认删除</button>
      </view>
    </view>
  </view>
</view>
