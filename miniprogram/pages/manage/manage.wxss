/* pages/manage/manage.wxss */
.page {
  padding: 20rpx 30rpx;
  min-height: 100vh;
  background: #f0f2f5;
}

/* ===== Header ===== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.title {
  font-size: 20px;
  font-weight: bold;
  color: #1d2129;
}
.header-actions {
  display: flex;
  gap: 10rpx;
}
.btn-add, .btn-import, .btn-export, .btn-config {
  font-size: 12px;
  padding: 8rpx 18rpx;
  border-radius: 6rpx;
  border: none;
  color: #fff;
  min-width: auto;
  height: auto;
  line-height: 1.6;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.12);
}
.btn-add { background: linear-gradient(135deg, #6366f1, #8b5cf6); }
.btn-config { background: #6b7280; }
.btn-import { background: #3b82f6; }
.btn-export { background: #10b981; }

/* ===== Search ===== */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 10rpx;
  padding: 0 18rpx;
  margin-bottom: 16rpx;
  position: relative;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.06);
}
.search-input {
  flex: 1;
  height: 76rpx;
  font-size: 14px;
  color: #333;
}
.search-clear {
  position: absolute;
  right: 18rpx;
  color: #999;
  font-size: 16px;
  padding: 10rpx;
}

/* ===== Server List ===== */
.server-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.server-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 22rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  transition: box-shadow 0.2s;
}
.server-item:active {
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}
.server-info {
  flex: 1;
}
.server-name {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}
.name {
  font-size: 16px;
  font-weight: 600;
  color: #1d2129;
}
.host-ip {
  font-size: 12px;
  color: #86909c;
  background: #f7f8fa;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}
.server-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.tag {
  font-size: 11px;
  padding: 3rpx 12rpx;
  border-radius: 100rpx;
  font-weight: 500;
}
.tag.alive { background: #e8f8e8; color: #10b981; }
.tag.slow { background: #fef7e6; color: #f59e0b; }
.tag.dead { background: #fef0ef; color: #ef4444; }
.group {
  font-size: 11px;
  color: #909399;
  background: #f0f0f0;
  padding: 3rpx 12rpx;
  border-radius: 100rpx;
}

/* ===== Server Actions ===== */
.server-actions {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}
.server-actions button {
  font-size: 11px;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  border: none;
  min-width: auto;
  height: auto;
  line-height: 1.5;
  font-weight: 500;
}
.btn-threshold {
  background: #3b82f6;
  color: #fff;
  box-shadow: 0 2rpx 4rpx rgba(59,130,246,0.25);
}
.btn-edit {
  background: #fff;
  color: #3b82f6;
  border: 1rpx solid #3b82f6;
}
.btn-delete {
  background: #fef2f2;
  color: #ef4444;
  border: 1rpx solid #fca5a5;
}
.btn-delete-confirm {
  background: #ef4444;
  color: #fff;
  border: none;
  box-shadow: 0 2rpx 4rpx rgba(239,68,68,0.3);
}

/* ===== Empty ===== */
.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #86909c;
  font-size: 14px;
}

/* ===== Modal ===== */
.modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
.modal-content {
  background: #fff;
  border-radius: 16rpx;
  padding: 36rpx 36rpx;
  width: 620rpx;
  max-height: 78vh;
  overflow-y: auto;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.16);
}
.modal-title {
  font-size: 18px;
  font-weight: 700;
  color: #1d2129;
  display: block;
  margin-bottom: 24rpx;
  text-align: center;
}
.modal-desc {
  font-size: 14px;
  color: #666;
  display: block;
  margin-bottom: 24rpx;
  white-space: pre-wrap;
  text-align: center;
  line-height: 1.8;
}

/* ===== Form Inputs ===== */
.modal-input {
  width: 100%;
  height: 72rpx;
  border: 1rpx solid #e5e6eb;
  border-radius: 8rpx;
  padding: 0 14rpx;
  font-size: 13px;
  margin-bottom: 12rpx;
  box-sizing: border-box;
  background: #fff;
  transition: border-color 0.2s;
}
.modal-input:focus {
  border-color: #6366f1;
}
.modal-input[disabled] {
  background: #f7f8fa;
  color: #86909c;
}
.modal-ip {
  display: block;
  font-size: 14px;
  color: #666;
  margin-bottom: 14rpx;
  padding: 16rpx;
  background: #f7f8fa;
  border-radius: 8rpx;
  font-weight: 500;
}
.section-title {
  font-size: 13px;
  font-weight: 600;
  color: #666;
  margin: 4rpx 0 10rpx 0;
  padding-top: 10rpx;
  border-top: 1rpx solid #e5e6eb;
}

/* ===== Modal Actions ===== */
.modal-actions {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-top: 22rpx;
}
.modal-cancel, .modal-confirm {
  font-size: 13px;
  padding: 12rpx 42rpx;
  border-radius: 8rpx;
  border: none;
  min-width: auto;
  height: auto;
  line-height: 1.5;
  font-weight: 500;
}
.modal-cancel {
  background: #f2f3f5;
  color: #666;
}
.modal-confirm {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(99,102,241,0.3);
}

/* ===== Threshold Form ===== */
.threshold-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.threshold-label {
  width: 140rpx;
  font-size: 13px;
  color: #333;
  flex-shrink: 0;
}
.threshold-input {
  flex: 1;
  height: 68rpx;
  border: 1rpx solid #e5e6eb;
  border-radius: 8rpx;
  padding: 0 14rpx;
  font-size: 13px;
  background: #fff;
}
.threshold-input:focus {
  border-color: #6366f1;
}

/* ===== Import Textarea ===== */
.import-textarea {
  width: 100%;
  height: 220rpx;
  border: 1rpx solid #e5e6eb;
  border-radius: 8rpx;
  padding: 14rpx;
  font-size: 13px;
  box-sizing: border-box;
  background: #fff;
  line-height: 1.6;
}
