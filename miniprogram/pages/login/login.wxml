<!-- pages/login/login.wxml -->
<view class="page">
  <view class="logo">🐷</view>
  <view class="title">服务器监控</view>
  <view class="subtitle">请登录后查看监控数据</view>

  <view class="form">
    <view class="input-group">
      <text class="label">账号</text>
      <input class="inp" placeholder="输入账号/邮箱" value="{{username}}" bindinput="onInputUser" cursor-spacing="200" adjust-position="true" />
    </view>
    <view class="input-group">
      <text class="label">密码</text>
      <input class="inp" password placeholder="输入密码" value="{{password}}" bindinput="onInputPwd" cursor-spacing="200" adjust-position="true" />
    </view>
    <button class="login-btn" bindtap="doLogin" loading="{{loading}}">登 录</button>
    <text class="error-msg" wx:if="{{error}}">{{error}}</text>
  </view>
</view>
